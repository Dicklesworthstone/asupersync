source: src/trace/tla_export.rs
expression: module.source
---
---- MODULE GoldenBehavior ----
EXTENDS Integers, Sequences, TLC

VARIABLES tasks, regions, obligations, time, step

TaskStates == {"Spawned", "Scheduled", "Polling", "Yielded", "Completed", "Cancelled"}
RegionStates == {"Open", "Closing", "Closed", "Cancelled"}
ObligationStates == {"Reserved", "Committed", "Aborted", "Leaked"}

Init ==
    /\ tasks = <<>>
    /\ regions = <<>>
    /\ obligations = <<>>
    /\ time = 0
    /\ step = 0

Next ==
    \/ /\ step = 0 /\ step' = 1
       /\ tasks' = <<>>
       /\ regions' = ("1.0" :> <<"Open", "NONE">>)
       /\ obligations' = <<>>
       /\ time' = 10
    \/ /\ step = 1 /\ step' = 2
       /\ tasks' = ("1.0" :> <<"Spawned", "1.0">>)
       /\ regions' = ("1.0" :> <<"Open", "NONE">>)
       /\ obligations' = <<>>
       /\ time' = 20
    \/ /\ step = 2 /\ step' = 3
       /\ tasks' = ("1.0" :> <<"Scheduled", "1.0">>)
       /\ regions' = ("1.0" :> <<"Open", "NONE">>)
       /\ obligations' = <<>>
       /\ time' = 30
    \/ /\ step = 3 /\ step' = 4
       /\ tasks' = ("1.0" :> <<"Polling", "1.0">>)
       /\ regions' = ("1.0" :> <<"Open", "NONE">>)
       /\ obligations' = <<>>
       /\ time' = 40
    \/ /\ step = 4 /\ step' = 5
       /\ tasks' = ("1.0" :> <<"Yielded", "1.0">>)
       /\ regions' = ("1.0" :> <<"Open", "NONE">>)
       /\ obligations' = <<>>
       /\ time' = 50
    \/ /\ step = 5 /\ step' = 6
       /\ tasks' = ("1.0" :> <<"Yielded", "1.0">>)
       /\ regions' = ("1.0" :> <<"Open", "NONE">>)
       /\ obligations' = ("1.0" :> <<"Reserved", "1.0", "1.0">>)
       /\ time' = 60
    \/ /\ step = 6 /\ step' = 7
       /\ tasks' = ("1.0" :> <<"Yielded", "1.0">>)
       /\ regions' = ("1.0" :> <<"Open", "NONE">>)
       /\ obligations' = ("1.0" :> <<"Committed", "1.0", "1.0">>)
       /\ time' = 70
    \/ /\ step = 7 /\ step' = 8
       /\ tasks' = ("1.0" :> <<"Completed", "1.0">>)
       /\ regions' = ("1.0" :> <<"Open", "NONE">>)
       /\ obligations' = ("1.0" :> <<"Committed", "1.0", "1.0">>)
       /\ time' = 80

\* Safety: no leaked obligations in terminal states
NoObligationLeaks ==
    \A o \in DOMAIN obligations:
        obligations[o][1] /= "Leaked"

\* Safety: completed tasks are not in open regions
QuiescenceOnClose ==
    \A r \in DOMAIN regions:
        regions[r][1] = "Closed" =>
            \A t \in DOMAIN tasks:
                tasks[t][2] = r => tasks[t][1] \in {"Completed", "Cancelled"}

\* Safety: obligation linearity (no double-commit/abort)
ObligationLinearity ==
    \A o \in DOMAIN obligations:
        obligations[o][1] \in ObligationStates

Spec == Init /\ [][Next]_<<tasks, regions, obligations, time, step>>

====
