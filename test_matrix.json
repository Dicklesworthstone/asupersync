{
  "smoke": [
    {
      "lane": {
        "id": "compile",
        "name": "Compile Check",
        "description": "Basic compilation check across platforms",
        "timeout": "5m",
        "commands": [
          "cargo check --all-targets",
          "cargo clippy -- -D warnings"
        ],
        "artifacts": [
          "compile-log.txt"
        ],
        "guarantees": [
          "code compiles",
          "no clippy warnings"
        ]
      },
      "platform": "ubuntu-latest",
      "platform_script": "linux",
      "features": [
        "io-uring",
        "epoll",
        "native-sockets"
      ],
      "dependencies": []
    },
    {
      "lane": {
        "id": "unit",
        "name": "Unit Tests",
        "description": "Fast unit test suite",
        "timeout": "8m",
        "commands": [
          "cargo test --lib --bins"
        ],
        "artifacts": [
          "unit-test-results.xml",
          "coverage-report.json"
        ],
        "guarantees": [
          "core logic correctness",
          "API contracts"
        ]
      },
      "platform": "ubuntu-latest",
      "platform_script": "linux",
      "features": [
        "io-uring",
        "epoll",
        "native-sockets"
      ],
      "dependencies": []
    },
    {
      "lane": {
        "id": "fmt",
        "name": "Format Check",
        "description": "Code formatting validation",
        "timeout": "2m",
        "commands": [
          "cargo fmt --check"
        ],
        "artifacts": [
          "fmt-check.txt"
        ],
        "guarantees": [
          "consistent code formatting"
        ]
      },
      "platform": "ubuntu-latest",
      "platform_script": "linux",
      "features": [
        "io-uring",
        "epoll",
        "native-sockets"
      ],
      "dependencies": []
    }
  ],
