{
  "contract_version": "capability-budget-planner-contract-v1",
  "owner_bead": "asupersync-3dhff2",
  "title": "Capability budget planner contract",
  "purpose": "Freeze the explicit resource-envelope planner for Cx, scopes, regions, and spawned task contexts so large swarm workloads cannot silently regain ambient or unbounded resource authority.",
  "proof_lane": "contract-and-runtime-ratchet",
  "proof_command": "rch exec -- env CARGO_INCREMENTAL=0 CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_capability_budget_planner_contract CARGO_PROFILE_TEST_DEBUG=0 RUSTFLAGS='-C debuginfo=0' cargo test -p asupersync --test capability_budget_planner_contract -- --nocapture",
  "required_dimensions": [
    {
      "dimension": "memory_bytes",
      "requirement_builder": "require_memory_bytes",
      "required_enum_variant": "MemoryBytes"
    },
    {
      "dimension": "cpu_units",
      "requirement_builder": "require_cpu_units",
      "required_enum_variant": "CpuUnits"
    },
    {
      "dimension": "io_bytes",
      "requirement_builder": "require_io_bytes",
      "required_enum_variant": "IoBytes"
    },
    {
      "dimension": "cleanup",
      "requirement_builder": "require_cleanup",
      "required_enum_variant": "Cleanup"
    },
    {
      "dimension": "artifact_bytes",
      "requirement_builder": "require_artifact_bytes",
      "required_enum_variant": "ArtifactBytes"
    }
  ],
  "runtime_semantics": [
    {
      "scenario_id": "child-inherits-and-tightens-every-dimension",
      "expected_status": "pass",
      "description": "Child envelopes inherit absent parent dimensions and only tighten present dimensions."
    },
    {
      "scenario_id": "required-dimension-missing-fails-closed",
      "expected_status": "pass",
      "description": "Required dimensions are rejected when neither parent nor child supplies an envelope."
    },
    {
      "scenario_id": "required-dimension-exhausted-fails-closed",
      "expected_status": "pass",
      "description": "Required dimensions are rejected when the effective envelope is already exhausted."
    },
    {
      "scenario_id": "cx-scope-region-task-propagation",
      "expected_status": "pass",
      "description": "Cx planning, scope construction, region admission, and task contexts carry the same explicit capability budget."
    },
    {
      "scenario_id": "e2e-log-captures-region-budget-deltas-cleanup-drain-and-no-leak",
      "expected_status": "pass",
      "description": "A deterministic runtime projection records admitted region ids, tightened budget deltas, cleanup drain quotas, fail-closed admission refusal, and a final no-obligation-leak state."
    },
    {
      "scenario_id": "lab-runtime-budget-exhaustion-fails-closed-deterministically",
      "expected_status": "pass",
      "description": "A seeded LabRuntime projection rejects exhausted required capability budgets identically across repeated runs and leaves no task or obligation residue."
    }
  ],
