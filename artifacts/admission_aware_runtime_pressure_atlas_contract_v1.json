    "future_witness_bead": "asupersync-bt63nr.5",
    "future_renderer_bead": "asupersync-bt63nr.10",
    "non_coverage": [
      "does not prove real-host throughput",
      "does not prove RCH fleet availability",
      "does not start or schedule proof lanes",
      "does not make production admission or backpressure on by default",
      "does not prove scheduler regression closure",
      "does not prove per-region allocator enforcement",
      "does not prove deadlock from spectral warnings alone"
    ]
  },
  "required_sections": [
    "lock_contention",
    "scheduler_pressure",
    "region_memory_budget_pressure",
    "spectral_wait_graph",
    "trapped_cycle_witness",
    "rch_proof_lane_admission",
    "dirty_tree_peer_ownership",
    "agent_mail_reservations",
    "br_tracker_status",
    "large_host_worker_warmth",
    "claim_boundary_labels",
    "operator_closeout_receipt"
  ],
  "sections": [
