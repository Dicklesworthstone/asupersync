    {
      "section_id": "large_host_worker_warmth",
      "description": "64-core/256GiB host profile, RCH worker capacity, NUMA, disk, cache-warmth, active-project exclusion, and advisory batching hints.",
      "owner_source": "artifacts/proof_lane_admission_input_schema_v1.json",
      "implementation_source": "src/runtime/resource_monitor.rs",
      "required_fields": [
