        "overall_label",
        "decision",
        "reason_codes",
        "source_rows",
        "proof_command",
        "cover_claims",
        "does_not_cover_claims",
        "freshness_summary",
        "recommended_next_action"
      ],
      "claim_boundary": "reporting layer only; does not itself validate proof success"
    }
  ],
  "field_ownership": [
    {
      "field": "sample_freshness",
      "owner_source": "admission-aware-runtime-pressure-atlas-v1",
      "description": "All externally supplied rows must declare freshness so stale snapshots fail closed."
    },
    {
      "field": "deadlock_proven",
      "owner_source": "trapped_cycle_witness",
      "description": "May be true only when a validated trapped-cycle witness row is present."
    },
    {
      "field": "production_admission_default_enabled",
      "owner_source": "scope_boundary",
      "description": "Must remain false for this schema-only contract."
    },
    {
      "field": "local_fallback_allowed",
      "owner_source": "runtime_pressure_control_evidence_contract_v1",
      "description": "Remote-required proof lanes must preserve local fallback refusal evidence."
    },
    {
      "field": "overlap_classification",
      "owner_source": "agent-mail-reservations+dirty-tree+br-tracker",
      "description": "Caller-supplied read-only overlap class that distinguishes owned work, peer conflicts, expired reservations, tracker-only changes, unrelated peer work, and malformed coordination rows."
    },
    {
      "field": "coordination_decision",
      "owner_source": "admission-aware-runtime-pressure-atlas-v1",
      "description": "Builder-derived conservative proceed, defer, handoff_required, or blocked decision for read-only coordination rows."
    },
    {
      "field": "worker_saturation",
      "owner_source": "admission-aware-runtime-pressure-atlas-v1",
      "description": "Builder-derived large-host saturation class from queue state, available cores, available memory, disk headroom, and host shape."
    },
    {
      "field": "advisory_batching_decision",
      "owner_source": "admission-aware-runtime-pressure-atlas-v1",
      "description": "Builder-derived advisory-only batching decision; never allocator enforcement, throughput proof, or production admission policy."
    },
    {
      "field": "advisory_non_claims",
      "owner_source": "admission-aware-runtime-pressure-atlas-v1",
      "description": "Explicit row-level non-claims that must include allocator_enforcement, throughput_improvement, and production_admission_default."
    }
  ],
  "large_host_advisory_profile": {
    "target_cpu_cores": 64,
    "target_memory_gib": 256,
    "minimum_numa_nodes": 2,
    "batch_core_floor": 8,
    "batch_memory_floor_gib": 64,
    "disk_headroom_floor_gib": 128,
    "planner_boundary": "advisory_batching_only",
    "non_claims": [
      "allocator_enforcement",
      "production_admission_default",
      "throughput_improvement"
    ],
    "deterministic_fixture_cases": [
      {
        "case_id": "large_host_admission",
        "worker_saturation": "available",
        "expected_decision": "prefer_warm_worker",
        "required_reason_codes": [
          "large_host_shape_64_core_256_gib",
          "target_dir_isolated",
          "active_project_excluded",
          "proof_lane_cost_estimate_present",
          "worker_cache_warm",
          "advisory_batching_only"
        ]
      },
      {
        "case_id": "large_host_low_memory_queueing",
        "worker_saturation": "low_memory",
        "expected_decision": "queue_low_memory",
        "required_reason_codes": [
          "worker_memory_low",
          "advisory_batching_only"
        ]
      },
      {
        "case_id": "large_host_worker_saturation",
        "worker_saturation": "worker_saturated",
        "expected_decision": "defer_worker_saturated",
        "required_reason_codes": [
          "worker_queue_saturated",
          "worker_core_saturation",
          "advisory_batching_only"
        ]
      },
      {
        "case_id": "large_host_cold_cache_batching",
        "worker_saturation": "available",
        "expected_decision": "admit_batch",
        "required_reason_codes": [
          "worker_cache_cold",
          "advisory_batching_only"
        ]
      }
    ]
  },
  "freshness_policy": {
    "required_for_all_external_rows": true,
    "freshness_statuses": [
      "fresh",
      "stale",
      "missing",
      "unsupported",
      "malformed"
    ],
    "stale_or_missing_default_outcome": "stale_evidence",
    "malformed_default_outcome": "validation_blocked",
    "unsupported_default_outcome": "validation_blocked",
    "clock_source_policy": "Rows may use wall-clock timestamps only as provenance. Deterministic lab rows should prefer fixed step or scenario identifiers."
  },
  "claim_labels": [
    {
      "label": "advisory",
      "description": "Evidence is useful for triage but does not prove runtime throughput, production policy safety, or deadlock.",
      "required_evidence": [
        "source_row",
        "sample_freshness"
      ],
      "forbidden_overclaims": [
        "real-host throughput",
        "production admission enabled",
        "deadlock proven"
      ]
    },
    {
      "label": "replay_backed",
      "description": "A deterministic lab or replay scenario supports the cited diagnosis for fixed inputs.",
      "required_evidence": [
        "source_row",
        "sample_freshness",
        "replay_command"
      ],
      "forbidden_overclaims": [
        "real-host throughput beyond the replayed scenario"
      ]
    },
    {
      "label": "trapped_cycle_proven",
      "description": "A trapped-cycle witness validates the deadlock-style claim.",
      "required_evidence": [
        "trapped_cycle_witness",
        "wait_edges",
        "held_resources",
        "replay_command"
      ],
      "forbidden_overclaims": [
        "global deadlock beyond the witnessed cycle"
      ]
    },
    {
      "label": "deadlock_proven",
      "description": "Alias label for closeouts that need the word deadlock; only valid with the same trapped-cycle witness requirements.",
      "required_evidence": [
        "trapped_cycle_witness",
        "wait_edges",
        "held_resources",
        "replay_command"
      ],
      "forbidden_overclaims": [
        "spectral-only deadlock proof"
      ]
    },
    {
      "label": "validation_blocked",
      "description": "The lane could not produce a green proof and must name the first blocker.",
      "required_evidence": [
        "source_row",
        "blocker_code"
      ],
      "forbidden_overclaims": [
        "green validation"
      ]
    },
    {
      "label": "stale_evidence",
      "description": "A required snapshot, reservation, tracker row, or worker receipt is too old or missing.",
      "required_evidence": [
        "freshness_status",
        "source_row"
      ],
      "forbidden_overclaims": [
        "current admission decision"
      ]
    }
  ],
  "negative_cases": [
    {
      "case_id": "deadlock_proven_without_trapped_cycle_witness",
      "input_pattern": {
        "claim_label": "deadlock_proven",
        "trapped_cycle_witness": null
      },
      "expected_outcome": "validation_blocked",
      "required_reason_code": "missing_trapped_cycle_witness"
    },
    {
      "case_id": "spectral_warning_overclaimed_as_deadlock",
      "input_pattern": {
        "section": "spectral_wait_graph",
        "early_warning_severity": "critical",
        "deadlock_proven": false
      },
      "expected_outcome": "advisory",
      "required_reason_code": "trapped_cycle_detection_required"
    },
    {
      "case_id": "production_admission_implied_by_default",
      "input_pattern": {
        "production_admission_default_enabled": true
      },
      "expected_outcome": "validation_blocked",
      "required_reason_code": "production_admission_must_remain_opt_in"
    },
    {
      "case_id": "remote_required_with_local_fallback_allowed",
      "input_pattern": {
        "remote_required": true,
        "local_fallback_allowed": true
      },
      "expected_outcome": "validation_blocked",
      "required_reason_code": "local_fallback_refusal_required"
    },
    {
      "case_id": "stale_agent_mail_reservation_snapshot",
      "input_pattern": {
        "section": "agent_mail_reservations",
        "sample_freshness": "stale"
      },
      "expected_outcome": "stale_evidence",
      "required_reason_code": "reservation_snapshot_stale"
    },
    {
      "case_id": "active_exclusive_agent_mail_conflict",
      "input_pattern": {
        "section": "agent_mail_reservations",
        "exclusive": true,
        "overlap_classification": "active_exclusive_conflict"
      },
      "expected_outcome": "defer",
      "required_reason_code": "active_exclusive_agent_mail_conflict"
    },
    {
      "case_id": "peer_owned_dirty_tree_overlap",
      "input_pattern": {
        "section": "dirty_tree_peer_ownership",
        "overlap_classification": "peer_exact",
        "handoff_required": true
      },
      "expected_outcome": "handoff_required",
      "required_reason_code": "peer_dirty_tree_overlap"
    },
    {
      "case_id": "expired_agent_mail_reservation",
      "input_pattern": {
        "section": "agent_mail_reservations",
        "overlap_classification": "expired_reservation"
      },
      "expected_outcome": "proceed",
      "required_reason_code": "expired_agent_mail_reservation"
    },
    {
      "case_id": "tracker_only_dirty_tree_change",
      "input_pattern": {
        "section": "dirty_tree_peer_ownership",
        "overlap_classification": "tracker_only"
      },
      "expected_outcome": "proceed",
      "required_reason_code": "tracker_only_dirty_tree_change"
    },
    {
      "case_id": "large_host_low_memory_queueing",
      "input_pattern": {
        "section": "large_host_worker_warmth",
        "worker_saturation": "low_memory"
      },
      "expected_outcome": "queue_low_memory",
      "required_reason_code": "worker_memory_low"
    },
    {
      "case_id": "large_host_worker_saturation_defer",
      "input_pattern": {
        "section": "large_host_worker_warmth",
        "worker_saturation": "worker_saturated"
      },
      "expected_outcome": "defer_worker_saturated",
      "required_reason_code": "worker_queue_saturated"
    },
    {
      "case_id": "large_host_warm_worker_preference",
      "input_pattern": {
        "section": "large_host_worker_warmth",
        "cache_warmth": "warm",
        "active_project_excluded": true
      },
      "expected_outcome": "prefer_warm_worker",
      "required_reason_code": "worker_cache_warm"
    },
    {
      "case_id": "large_host_advisory_overclaim_guard",
      "input_pattern": {
        "section": "large_host_worker_warmth",
        "advisory_only": true,
        "advisory_non_claims": [
          "allocator_enforcement",
          "production_admission_default",
          "throughput_improvement"
        ]
      },
      "expected_outcome": "advisory",
      "required_reason_code": "advisory_batching_only"
    },
    {
      "case_id": "unrelated_peer_work",
      "input_pattern": {
        "section": "dirty_tree_peer_ownership",
        "overlap_classification": "unrelated_peer_work"
      },
      "expected_outcome": "proceed",
      "required_reason_code": "unrelated_peer_work"
    }
  ],
  "validation": {
    "proof_command": "RCH_REQUIRE_REMOTE=1 rch exec -- env CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_admission_aware_runtime_pressure_atlas_contract CARGO_INCREMENTAL=0 CARGO_PROFILE_TEST_DEBUG=0 RUSTFLAGS='-D warnings -C debuginfo=0' cargo test -p asupersync --test admission_aware_runtime_pressure_atlas_contract -- --nocapture",
    "expected_signal": "admission_aware_runtime_pressure_atlas_contract tests pass",
    "does_not_cover": [
      "runtime snapshot builder implementation",
      "proof-lane admission planner implementation",
      "renderer implementation",
      "RCH fleet availability",
      "production runtime throughput"
    ]
  }
}
