      ],
      "claim_boundary": "label controls how the report may be cited"
    },
    {
      "section_id": "operator_closeout_receipt",
      "description": "Agent-Mail-ready receipt that composes the atlas verdict, source rows, proof command, non-claims, and recommended next action.",
      "owner_source": "asupersync-bt63nr.10",
      "implementation_source": "src/lab/swarm_replay.rs",
      "required_fields": [
