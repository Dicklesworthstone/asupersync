    "reservation_work_finder_script": "scripts/reservation_aware_work_finder.py",
    "reservation_work_finder_test": "tests/reservation_aware_work_finder_contract.rs",
    "swarm_proof_lane_contract": "artifacts/swarm_proof_lane_planner_contract_v1.json",
    "swarm_proof_lane_test": "tests/swarm_proof_lane_planner_contract.rs",
    "swarm_proof_lane_source": "src/lab/swarm_replay.rs",
    "operator_runbook": "docs/runtime_pressure_triage_runbook.md",
    "tracker_inventory_bead": "asupersync-bt63nr.1"
  },
  "scope_boundary": {
    "defines_schema_only": true,
    "builds_runtime_snapshot": false,
    "starts_proof_lanes": false,
    "runs_cargo": false,
    "runs_rch": false,
