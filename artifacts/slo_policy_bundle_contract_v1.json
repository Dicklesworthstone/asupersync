  "gate_contract": {
    "mode": "deterministic fail-closed schema validation",
    "provenance": "profile_id, profile_hash, observed_profile_hash, target_commit, feature_flags, artifact_path, and related_bead_id are preserved in JSON",
    "slo_objectives": "latency percentiles must be positive, monotonic, supported-unit, and compatible with cleanup deadlines",
    "resource_pressure": "memory and fd thresholds are basis points and timer queue depth must be positive",
    "fallback": "every bundle must declare a no-win fallback and an rch-routed proof command",
    "redaction": "redaction.passed must be true and metadata/commands must not contain secret-like material",
    "paths": "file-backed provenance must stay repository-relative and avoid host-private path fragments",
    "malformed_input": "malformed bundle JSON or JSONL fails closed with malformed_json"
  },
