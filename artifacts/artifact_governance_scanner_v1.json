  "created_date": "2026-06-12",
  "purpose": "Representative deterministic scan result that links durable artifact paths to owner signals, tests, docs references, proof manifest rows, proof status rows, ledger overrides, and citation categories without claiming full-corpus coverage.",
  "source_of_truth": {
    "scanner_artifact": "artifacts/artifact_governance_scanner_v1.json",
    "operator_report": "docs/proof/artifact_governance_scanner.md",
    "contract_test": "tests/artifact_governance_scanner_contract.rs",
    "ledger": "artifacts/artifact_governance_ledger_v1.json",
    "agent_instructions": "AGENTS.md"
  },
  "coverage_policy": {
    "corpus_coverage": "representative_contract_scan_not_full_corpus",
    "full_corpus_claim": false,
    "non_destructive": true,
    "stable_sort_order": "artifact_path_then_category_bytewise",
    "parser_policy": "Structured artifact inputs are parsed as JSON. Markdown and Rust references are collected as literal repository-relative path references and checked deterministically by the contract. The scanner does not rewrite, move, or delete artifacts."
  },
  "confidence_catalog": {
    "exact_bead_id_field": {
      "rank": 1,
      "meaning": "The artifact JSON exposes a top-level bead_id field that names the owner.",
      "false_positive_boundary": "Does not prove the artifact is current or citeable without its contract lane."
    },
    "domain_specific_owner_field": {
      "rank": 2,
      "meaning": "The artifact JSON exposes a domain-specific owner field such as track_bead_id that needs scanner-specific interpretation.",
      "false_positive_boundary": "Does not override the governance ledger or prove closure-grade evidence."
    },
    "proof_manifest_source_path": {
      "rank": 3,
      "meaning": "The proof manifest lists the artifact path in a lane's source_paths or supporting metadata.",
      "false_positive_boundary": "Does not prove that the lane passed."
    },
    "proof_status_lane_mapping": {
      "rank": 4,
      "meaning": "The proof status snapshot maps a claim to a lane or command that cites the artifact path.",
      "false_positive_boundary": "Does not prove fresh proof evidence; rerun-required and blocked rows stay non-green evidence."
    },
    "readme_agents_reference": {
      "rank": 5,
      "meaning": "README.md or AGENTS.md names the artifact path or its canonical proof surface.",
      "false_positive_boundary": "Documentation references are citation cues, not owner proof."
    },
    "test_constant_path": {
      "rank": 6,
      "meaning": "A checked test contains the artifact path as a constant or include_str source.",
      "false_positive_boundary": "Does not prove the artifact is exhaustive or semantically fresh."
    },
    "manual_ledger_override": {
      "rank": 7,
      "meaning": "The artifact governance ledger supplies an explicit owner, exclusion, or supersession row.",
      "false_positive_boundary": "Manual overrides must stay visible and do not authorize deletion."
    }
  },
  "category_catalog": {
    "exact_ownership": {
      "meaning": "The scanner found a direct owner signal with no conflicting owner signal in the representative corpus.",
      "scanner_rule": "At least one confidence source has kind exact_bead_id_field or manual_ledger_override and all owner beads agree.",
      "no_claim_boundaries": [
        "does_not_prove_full_corpus_coverage",
        "does_not_prove_fresh_rch_pass",
        "does_not_prove_workspace_health"
      ]
    },
    "inferred_ownership": {
      "meaning": "The scanner found a plausible owner through domain-specific fields, tests, docs, or proof metadata, but not a canonical bead_id-only owner.",
      "scanner_rule": "Confidence sources include domain_specific_owner_field, proof_manifest_source_path, proof_status_lane_mapping, readme_agents_reference, or test_constant_path without a conflict.",
      "no_claim_boundaries": [
        "does_not_override_manual_ledger",
        "does_not_prove_acceptance_criteria",
        "does_not_close_owner_bead"
      ]
    },
    "orphan": {
      "meaning": "The artifact exists and is referenced, but the scanner did not find a governance ledger row or proof-lane owner sufficient for citation.",
      "scanner_rule": "Artifact path exists, reference sites exist, and ledger_rows plus proof_manifest_rows plus proof_status_rows are empty.",
      "no_claim_boundaries": [
        "does_not_authorize_deletion",
        "does_not_prove_artifact_unused",
        "does_not_prove_owner_absence"
      ]
    },
    "ambiguous": {
      "meaning": "The scanner found conflicting owner signals that require an explicit ledger override or follow-up.",
      "scanner_rule": "Two or more owner bead signals disagree, or an artifact owner field conflicts with the ledger row.",
      "no_claim_boundaries": [
        "does_not_select_a_winner",
        "does_not_close_followup",
        "does_not_prove_current_artifact_health"
      ]
    },
    "stale": {
      "meaning": "The artifact is retained for lineage but must not be cited as current because a successor path exists.",
      "scanner_rule": "superseded_by is set and points to an existing successor artifact.",
      "no_claim_boundaries": [
        "does_not_prove_current_result",
        "does_not_override_successor_artifact",
        "does_not_authorize_deletion"
      ]
    },
    "excluded": {
      "meaning": "The path or path family is intentionally outside durable artifact governance for this scanner version.",
      "scanner_rule": "exclusion_reason is set and the path is a generated or ephemeral pattern.",
      "no_claim_boundaries": [
        "does_not_authorize_deletion",
        "does_not_hide_future_durable_artifacts",
        "does_not_prove_artifact_absence"
      ]
    }
  },
