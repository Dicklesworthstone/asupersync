    "trace_metadata": "uses existing trace::replay::TraceMetadata with deterministic seed, config hash digest, description, and virtual-time recorded_at",
    "ambient_inputs": "no wall-clock, randomness, network, host path traversal, hidden downloads, or best-effort mock replay"
  },
