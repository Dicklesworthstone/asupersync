{
  "schema_version": "swarm-admission-decision-contract-v1",
  "bead_id": "asupersync-vjc3pv.2",
  "capability_id": "deterministic_swarm_admission_decision",
  "artifact_path": "artifacts/swarm_admission_decision_contract_v1.json",
  "contract_test": "tests/swarm_admission_decision_contract.rs",
  "generated_at_utc": "2026-05-19T00:06:00Z",
  "support_class": "artifact-contract-backed",
  "side_effect_policy": {
    "mode": "report_only",
    "beads_mutation_allowed": false,
    "agent_mail_mutation_allowed": false,
    "filesystem_cleanup_allowed": false,
    "cargo_execution_allowed": false,
    "notes": "The admission decision contract is consumed by operators and future runtime code; it never authorizes cleanup, tracker mutation, branch creation, or local Cargo fallback by itself."
  },
  "required_input_classes": [
    "capacity_snapshot",
    "proof_lane_status",
    "agent_mail_reservation_pressure",
    "beads_backlog_state",
    "host_pressure_snapshot",
    "rch_admissibility"
  ],
  "allowed_pressure_sources": [
    "agent_mail",
    "beads",
    "cgroup_v2",
    "procfs",
    "rch_receipt"
  ],
  "required_decision_outputs": [
    "admit_full",
    "brownout_degraded_optional",
    "no_win",
    "defer_tracker_blocked",
    "fail_closed_stale_evidence",
    "fail_closed_unsupported_host_data",
    "fail_closed_malformed_input",
    "fail_closed_local_rch_fallback"
  ],
  "decision_priority_order": [
    "malformed_input",
    "unsupported_pressure_source",
    "local_rch_fallback",
    "stale_evidence",
    "tracker_blocked",
    "remote_required_no_worker",
    "brownout_pressure",
    "admit_full"
  ],
  "decision_rules": [
    {
      "rule_id": "malformed-input",
      "priority": 10,
      "trigger": "input_status == malformed",
      "decision": "fail_closed_malformed_input",
      "required_issue_kind": "malformed_input",
      "operator_action": "reject receipt and request a fresh complete snapshot"
    },
    {
      "rule_id": "unsupported-pressure-source",
      "priority": 20,
      "trigger": "host_pressure_snapshot.pressure_source not in allowed_pressure_sources",
      "decision": "fail_closed_unsupported_host_data",
      "required_issue_kind": "unsupported_pressure_source",
      "operator_action": "reject receipt and capture a supported pressure source"
    },
    {
      "rule_id": "local-rch-fallback",
      "priority": 30,
      "trigger": "proof_lane_status.local_fallback_marker_detected == true",
      "decision": "fail_closed_local_rch_fallback",
      "required_issue_kind": "local_rch_fallback",
      "operator_action": "discard as non-remote proof and rerun with RCH_REQUIRE_REMOTE=1"
    },
    {
      "rule_id": "stale-evidence",
      "priority": 40,
      "trigger": "proof_lane_status.evidence_age_seconds > staleness_policy.max_source_age_seconds",
      "decision": "fail_closed_stale_evidence",
      "required_issue_kind": "stale_evidence",
      "operator_action": "refresh capacity, proof, tracker, and pressure snapshots"
    },
    {
      "rule_id": "tracker-blocked",
      "priority": 50,
      "trigger": "beads_backlog_state.tracker_writable == false || agent_mail_reservation_pressure.tracker_reserved == true",
      "decision": "defer_tracker_blocked",
      "required_issue_kind": "tracker_blocked",
      "operator_action": "proceed source-only only when source reservations are clean, otherwise wait for tracker release"
    },
    {
      "rule_id": "remote-required-no-worker",
      "priority": 60,
      "trigger": "rch_admissibility.remote_required == true && rch_admissibility.workers_admissible == false",
      "decision": "no_win",
      "required_issue_kind": "remote_worker_unavailable",
      "required_receipt": "no_win_receipt",
      "operator_action": "record no-win receipt without claiming validation success"
    },
    {
      "rule_id": "brownout-pressure",
      "priority": 70,
      "trigger": "host_pressure_snapshot.disk_critical == true || host_pressure_snapshot.memory_pressure_bps >= 9000 || host_pressure_snapshot.cpu_saturation_bps >= 9000",
      "decision": "brownout_degraded_optional",
      "required_issue_kind": "brownout_pressure",
      "required_receipt": "brownout_receipt",
      "operator_action": "admit only critical work and shed optional proof/dashboard work"
    },
    {
      "rule_id": "admit-full",
      "priority": 80,
      "trigger": "all required snapshots are fresh, supported, and below pressure thresholds",
      "decision": "admit_full",
      "required_issue_kind": "",
      "operator_action": "claim the bead, reserve exact files, and run remote-required proof lanes"
    }
  ],
  "staleness_policy": {
    "timestamp_basis": "source_timestamp_utc to collected_timestamp_utc",
    "max_source_age_seconds": 900,
    "stale_decision": "fail_closed_stale_evidence"
  },
  "validation": {
    "json_probe": "jq empty artifacts/swarm_admission_decision_contract_v1.json",
    "format_check": "rustfmt --edition 2024 --check tests/swarm_admission_decision_contract.rs",
    "remote_required_contract_test": "RCH_REQUIRE_REMOTE=1 rch exec -- env CARGO_TARGET_DIR=/tmp/rch_target_boldtower_swarm_admission_contract CARGO_INCREMENTAL=0 cargo test -p asupersync --test swarm_admission_decision_contract -- --nocapture",
    "local_fallback_policy": "Any local fallback marker in an rch receipt is a fail-closed decision and cannot count as validation evidence."
  },
  "forbidden_command_fragments": [
    "git reset --hard",
    "git clean -fd",
    "rm -rf",
    "git worktree add",
    "git checkout -b",
    "git switch -c",
    "bare cargo test -p asupersync --test swarm_admission_decision_contract -- --nocapture"
  ],
