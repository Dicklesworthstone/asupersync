{
  "contract_version": "swarm-failure-minimizer-contract-v1",
  "schema_version": "asupersync.swarm-failure-minimizer.v1",
  "bead_id": "asupersync-vssefs.9.5",
  "description": "Stable deterministic minimizer contract for shrinking failing swarm replay scenarios while preserving invariant reproduction evidence, proof-lane provenance, redaction policy, and owner routing.",
  "source_of_truth": {
    "contract": "artifacts/swarm_failure_minimizer_contract_v1.json",
    "contract_test": "tests/swarm_failure_minimizer_contract.rs",
    "runtime_input_type": "asupersync::lab::SwarmFailureMinimizerInput",
    "runtime_report_type": "asupersync::lab::SwarmFailureMinimizerReport",
    "runtime_minimizer_source": "src/lab/swarm_replay.rs",
    "runtime_minimizer": "asupersync::lab::minimize_swarm_failure",
    "runtime_text_renderer": "asupersync::lab::render_swarm_failure_minimizer_text"
  },
  "schema": {
    "required_input_fields": [
      "minimizer_id",
      "original_scenario",
      "failure_bundle",
      "minimum_regions",
      "minimum_tasks_per_region",
      "minimum_replay_steps",
      "max_reduction_passes",
      "source_trace_ids",
      "replay_command"
    ],
    "required_bundle_fields": [
      "bundle_id",
      "original_artifact",
      "invariant_class",
      "invariant_reproduced",
      "first_failure",
      "trace_summary",
      "proof_lane_plan",
      "redaction_policy_id",
      "secret_like_value_count"
    ],
    "required_report_fields": [
      "schema_version",
      "minimizer_id",
      "bundle_id",
      "original_artifact",
      "original_scenario_id",
      "minimized_scenario",
      "replay_command",
      "verdict",
      "invariant_class",
      "first_failure",
      "stop_reason",
      "preserved_invariant",
      "required_fields_present",
      "missing_required_fields",
      "proof_lane_decision",
      "source_trace_ids",
      "redaction_policy_id",
      "redaction_preserved",
      "reduction_steps",
      "original_task_count",
      "minimized_task_count",
      "reduction_ratio_bps",
      "owner_surface",
      "owner_bead_hint",
      "routing_hints",
      "destructive_cleanup_required",
      "branch_or_worktree_required"
    ],
    "verdicts": [
      "minimized",
      "already_minimal",
      "non_reproducible",
      "incomplete"
    ],
    "stop_reasons": [
      "invariant_preserved",
      "already_minimal",
      "non_reproducible",
      "missing_evidence",
      "redaction_required",
      "invalid_scenario",
      "step_limit_reached"
    ],
    "invariant_classes": [
      "cancellation_storm",
      "deadlock_or_lost_wakeup",
      "obligation_leak",
      "admission_failure",
      "queue_pressure",
      "invariant_violation"
    ]
  },
  "acceptance": {
    "must_preserve_original_artifact_pointer": true,
    "must_preserve_redaction_policy": true,
    "must_require_ready_proof_lane": true,
    "must_require_reproduced_invariant_before_minimized": true,
    "must_never_request_destructive_cleanup": true,
    "must_never_request_branch_or_worktree": true,
    "focused_rch_validation": "RCH_REQUIRE_REMOTE=1 rch exec -- env CARGO_INCREMENTAL=0 CARGO_PROFILE_TEST_DEBUG=0 RUSTFLAGS='-C debuginfo=0' CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_swarm_failure_minimizer cargo test -p asupersync --test swarm_failure_minimizer_contract --features test-internals -- --nocapture"
  },
  "owner_routing": {
    "cancellation_storm": "src/cancel/mod.rs",
    "deadlock_or_lost_wakeup": "src/runtime/scheduler/three_lane.rs",
    "obligation_leak": "src/obligation/mod.rs",
    "admission_failure": "src/lab/swarm_replay.rs",
    "queue_pressure": "src/runtime/scheduler/three_lane.rs",
    "invariant_violation": "src/runtime/mod.rs"
  }
}
