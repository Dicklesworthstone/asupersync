        "command": "RCH_REQUIRE_REMOTE=1 rch exec -- env CARGO_INCREMENTAL=0 CARGO_PROFILE_TEST_DEBUG=0 RUSTFLAGS='-C debuginfo=0' CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_swarm_workload_scenario_corpus cargo test -p asupersync --test swarm_workload_scenario_corpus_contract --features test-internals -- --nocapture",
        "target_dir": "${TMPDIR:-/tmp}/rch_target_swarm_workload_scenario_corpus",
        "features": [
          "test-internals"
        ],
        "expected_artifacts": [
          "artifacts/swarm_workload_scenario_corpus_v1.json",
          "tests/swarm_workload_scenario_corpus_contract.rs",
          "target/lab-replay/swarm-workload/proof.json"
