        "timeout_secs": 1200,
        "remote_required": true,
        "local_fallback_authorized": false,
        "expected_head": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "observed_head": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
        "rch_provenance": {
          "worker_id": "rch-worker-fixture-01",
