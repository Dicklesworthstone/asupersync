{
  "schema_version": "incident-bundle-contract-v1",
  "bead_id": "asupersync-lkygsb.1",
  "module": "src/trace/incident.rs",
  "description": "Canonical contract for fail-closed production incident bundles that bridge crash packs, trace logs, support bundles, README claim failures, conformance failures, rch proof failures, and manual repro notes into deterministic replay work.",
  "source_kinds": [
    "crash_pack",
    "trace_log",
    "support_bundle",
    "readme_claim_failure",
    "conformance_failure",
    "rch_proof_failure",
    "repro_notes"
  ],
  "required_top_level_fields": [
    "schema_version",
    "bundle_id",
    "sources",
    "command",
    "determinism",
    "privacy",
    "provenance"
  ],
  "required_source_fields": [
    "source_id",
    "kind",
    "content_hash",
    "content_bytes",
    "redaction_status"
  ],
  "fail_closed_triggers": [
    "unsupported_schema_version",
    "missing_required_field",
    "duplicate_source_id",
    "unsupported_source_kind",
    "missing_redaction_policy",
    "redaction_required_but_missing",
    "secret_like_material",
    "oversized_field",
    "external_path",
    "malformed_content_hash",
    "binary_like_payload",
    "duplicate_feature_flag"
  ],
  "redaction_contract": {
    "policy_required": true,
    "confidential_or_secret_requires_redacted_status": true,
    "secret_like_key_fragments": [
      "authorization",
      "cookie",
      "credential",
      "passwd",
      "password",
      "private_key",
      "secret",
      "session",
      "token",
      "api_key"
    ],
    "secret_like_value_fragments": [
      "bearer ",
      "basic ",
      "sk-",
      "ghp_",
      "akia",
      "-----begin",
      ".ssh",
      "id_rsa"
    ],
    "host_private_path_fragments": [
      "/home/",
      "/users/",
      "c:\\users\\",
      "/.ssh/",
      "\\.ssh\\",
      "/appdata/",
      "\\appdata\\"
    ]
  },
  "determinism_contract": {
    "hash_format": "sha256:<64 hex characters>",
    "bundle_fingerprint": "stable local FNV-1a over deterministic JSON; not a security hash",
    "paths": "repository-relative only; absolute paths and parent traversal are blocked",
    "ambient_inputs": "no wall-clock, randomness, network, host path traversal, or hidden downloads"
  },
