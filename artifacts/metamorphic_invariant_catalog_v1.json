  "description": "Grep-able catalog of existing metamorphic invariants and their TransformFamily tags.",
  "source_of_truth": {
    "artifact": "artifacts/metamorphic_invariant_catalog_v1.json",
    "contract_test": "tests/metamorphic_invariant_catalog_contract.rs",
    "proof_command": "rch exec -- env CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_metamorphic_invariant_catalog CARGO_BUILD_JOBS=2 cargo test -p asupersync --test metamorphic_invariant_catalog_contract -- --nocapture"
  },
  "catalog_rules": {
    "transform_family_tag_prefix": "TransformFamily::",
    "source_paths_are_repo_relative": true,
    "source_markers_must_exist": true,
    "risk_focus_must_be_nonempty": true
  },
  "transform_families": [
    {
      "tag": "TransformFamily::Backpressure",
      "description": "Input pressure changes preserve explicit capacity and blocking semantics."
    },
    {
      "tag": "TransformFamily::CancellationSafety",
      "description": "Cancellation timing changes do not leak obligations, consume notifications, or lose committed values."
    },
    {
      "tag": "TransformFamily::Equivalence",
      "description": "Alternative API paths or operation orders produce equivalent externally visible results."
    },
    {
      "tag": "TransformFamily::Causality",
      "description": "Earlier lifecycle events constrain later observations, such as receiver subscription or channel closure."
    },
    {
      "tag": "TransformFamily::Quiescence",
      "description": "Closing scopes or regions implies all owned work has reached a terminal state."
    },
    {
      "tag": "TransformFamily::Ordering",
      "description": "Parent-child, FIFO, insertion, or priority ordering relationships remain stable under valid transforms."
    },
    {
      "tag": "TransformFamily::LoserDrain",
      "description": "Race or timeout losers are cancelled and drained before the winner surface returns."
    },
    {
      "tag": "TransformFamily::Deadline",
      "description": "Deadline placement changes preserve timeout/cancel precedence and boundary behavior."
    },
    {
      "tag": "TransformFamily::Fairness",
      "description": "Scheduler or lock contention transforms preserve bounded access and starvation freedom."
    },
    {
      "tag": "TransformFamily::ResourceLeak",
      "description": "Dropped or cancelled waiters do not remain in queues or affect later operations."
    },
    {
      "tag": "TransformFamily::Exclusion",
      "description": "Mutual exclusion and writer-preference properties hold under reader/writer contention transforms."
    },
    {
      "tag": "TransformFamily::TemporalCoverage",
      "description": "Virtual-time advancement transforms preserve due-work coverage and timer migration."
    },
    {
      "tag": "TransformFamily::Replay",
      "description": "Recording, replay, minimization, and compression preserve trace behavior or failure class."
    },
    {
      "tag": "TransformFamily::Permutation",
      "description": "Reordering independent events preserves analysis results while exposing dependence when present."
    },
    {
      "tag": "TransformFamily::Priority",
      "description": "Priority-lane transforms preserve relative throughput and admission guarantees."
    },
    {
      "tag": "TransformFamily::CapabilityAttenuation",
      "description": "Capability restriction transforms only reduce authority and preserve parent-child bounds."
    },
    {
      "tag": "TransformFamily::Monotonicity",
      "description": "State transitions such as generation or budget progression move in one direction."
    },
    {
      "tag": "TransformFamily::Reversibility",
      "description": "Acquire/release or encode/decode pairs return observable state to the original projection."
    }
  ],
