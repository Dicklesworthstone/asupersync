{
  "schema_version": "artifact-governance-ledger-v1",
  "ledger_id": "artifact_governance_ledger_v1",
  "bead_id": "asupersync-artifact-governance-awdiwy.1",
  "created_date": "2026-06-12",
  "purpose": "Define the first durable artifact-governance schema, citeability taxonomy, and non-destructive exclusion policy for representative proof, validation, RCH, runtime-pressure, swarm, browser/wasm, and RaptorQ artifact families.",
  "source_of_truth": {
    "ledger": "artifacts/artifact_governance_ledger_v1.json",
    "contract_test": "tests/artifact_governance_ledger_contract.rs",
    "agent_instructions": "AGENTS.md",
    "testing_decision_tree": "TESTING_FOR_AGENTS.md"
  },
  "coverage_policy": {
    "corpus_coverage": "seeded_representative_not_exhaustive",
    "full_corpus_claim": false,
    "exclusion_policy": "Excluded rows are explicit governance declarations for paths or path families this ledger version must not treat as durable artifacts. Exclusion never authorizes deletion, mutation, or ignoring future evidence.",
    "missing_artifact_policy": "A missing_expected_artifact row is a fail-closed pointer to a canonical artifact named by docs or tests but absent from the current tree. It is not citeable proof until the artifact exists and its contract passes on current main.",
    "non_destructive_policy": "This ledger records ownership and citeability only. It does not delete files, clean generated output, create branches, create worktrees, or permit local Cargo fallback for remote-required proof lanes."
  },
  "field_definitions": {
    "artifact_id": {
      "meaning": "Stable row identifier for this governance ledger.",
      "no_claim_boundary": "Does not imply the underlying artifact is current, complete, or proof-bearing."
    },
    "path": {
      "meaning": "Repository-relative path, or explicit path pattern for excluded generated families.",
      "no_claim_boundary": "Does not imply the path exists unless path_status says tracked."
    },
    "path_status": {
      "meaning": "Current-tree status used by the ledger contract to decide whether path existence is required.",
      "no_claim_boundary": "Does not repair missing artifacts or certify generated paths."
    },
    "owning_bead": {
      "meaning": "Primary bead responsible for maintaining the row or the artifact family.",
      "no_claim_boundary": "Does not close the bead or transfer peer-owned work."
    },
    "producing_lane": {
      "meaning": "Lane, contract, runner, or workflow that is expected to produce or validate the artifact.",
      "no_claim_boundary": "Does not prove that the lane has passed on current main."
    },
    "domain": {
      "meaning": "Human-readable subsystem or operator domain for routing ownership.",
      "no_claim_boundary": "Does not imply exclusive code ownership."
    },
    "artifact_family": {
      "meaning": "Normalized family bucket used for seed coverage and future scanner grouping.",
      "no_claim_boundary": "Does not claim every artifact in the family is listed."
    },
    "checked_by_tests": {
      "meaning": "Repository tests or contract files that are expected to validate the artifact shape, policy, or related surface.",
      "no_claim_boundary": "Does not claim those tests passed unless a fresh proof receipt is attached elsewhere."
    },
    "citeability_class": {
      "meaning": "Taxonomy value that governs whether agents may cite this row as proof, advisory context, a blocker, a superseded artifact, generated fixture evidence, operator report, or explicit exclusion.",
      "no_claim_boundary": "Does not expand the artifact beyond its row-level evidence_scope and no_claim_boundaries."
    },
    "freshness_policy": {
      "meaning": "Rule for deciding when this row must be refreshed before citation.",
      "no_claim_boundary": "Does not create a fresh proof by itself."
    },
    "superseded_by": {
      "meaning": "Replacement artifact path when citeability_class is superseded; otherwise null.",
      "no_claim_boundary": "Does not delete or rewrite the superseded artifact."
    },
    "no_claim_boundaries": {
      "meaning": "Machine-readable boundaries that name what this row must not be cited to prove.",
      "no_claim_boundary": "Does not waive any AGENTS.md validation, RCH, branch, worktree, or deletion rule."
    },
    "exclusion_reason": {
      "meaning": "Required reason when citeability_class is excluded; null otherwise.",
      "no_claim_boundary": "Does not authorize deleting excluded files or ignoring new durable artifacts."
    },
    "evidence_scope": {
      "meaning": "Plain-language scope of what the artifact can and cannot support.",
      "no_claim_boundary": "Does not override citeability_class or no_claim_boundaries."
    },
    "source_references": {
      "meaning": "Existing repo files that explain, test, or document the row.",
      "no_claim_boundary": "Does not imply those references are exhaustive or current proof receipts."
    }
  },
  "classification_catalog": {
    "proof-bearing": {
      "meaning": "Narrowly citeable for the exact artifact contents and contract named by the row.",
      "cite_rule": "May be cited only with its evidence_scope, checked_by_tests, freshness_policy, and no_claim_boundaries.",
      "does_not_prove": [
        "does_not_prove_full_workspace_health",
        "does_not_prove_release_readiness",
        "does_not_authorize_local_cargo_fallback"
      ]
    },
    "advisory": {
      "meaning": "Useful context or mixed-signal evidence that must not be treated as closure-grade proof.",
      "cite_rule": "May be cited as context only, with the row's no-claim boundaries attached.",
      "does_not_prove": [
        "does_not_prove_acceptance_criteria",
        "does_not_prove_no_regression",
        "does_not_close_blockers"
      ]
    },
    "blocked-frontier": {
      "meaning": "Known frontier, stale, missing, or admission-blocked artifact whose existence documents a blocker rather than proof.",
      "cite_rule": "May be cited only as a blocker or gap until the artifact exists and a fresh remote-required proof receipt passes.",
      "does_not_prove": [
        "does_not_prove_source_correctness",
        "does_not_prove_rch_success",
        "does_not_prove_current_main_health"
      ]
    },
    "superseded": {
      "meaning": "Tracked historical artifact retained for lineage but replaced by superseded_by for current citation.",
      "cite_rule": "May be cited only for historical lineage, never as current evidence.",
      "does_not_prove": [
        "does_not_prove_current_result",
        "does_not_override_successor_artifact",
        "does_not_authorize_deletion"
      ]
    },
    "generated-fixture": {
      "meaning": "Inventory or fixture describing generated or reproducible output without committing the raw output tree.",
      "cite_rule": "May be cited for retention and reproduction policy only when the inventory contract is fresh.",
      "does_not_prove": [
        "does_not_prove_generated_outputs_exist_locally",
        "does_not_authorize_deletion",
        "does_not_prove_runtime_correctness"
      ]
    },
    "operator-report": {
      "meaning": "Human/operator-facing report that summarizes evidence or routing decisions but is not a substitute for source-level proof.",
      "cite_rule": "May be cited for operator decision context and routing hints only.",
      "does_not_prove": [
        "does_not_prove_broad_observability_correctness",
        "does_not_prove_performance_improvement",
        "does_not_prove_live_rch_fleet_availability"
      ]
    },
    "excluded": {
      "meaning": "Path or family intentionally outside this ledger's durable artifact surface.",
      "cite_rule": "May be cited only to explain why the ledger does not track that generated or ephemeral path family.",
      "does_not_prove": [
        "does_not_authorize_deletion",
        "does_not_hide_future_artifacts",
        "does_not_prove_artifact_absence"
      ]
    }
  },
  "path_status_catalog": {
    "tracked": "The path must exist in the repository at contract-test time.",
    "missing_expected_artifact": "The path must be absent and is tracked as a fail-closed artifact gap.",
    "generated_or_ignored": "The path is a generated output pattern or ignored cache family; existence is neither required nor trusted."
  },
  "required_family_seed_coverage": [
    "proof_manifest",
