  "validation_commands": [
    "rch exec -- rustfmt --edition 2024 --check tests/conformance/grpc_deadline.rs tests/conformance/grpc_health.rs",
    "bash -n scripts/run_grpc_deadline_health_conformance_evidence.sh",
    "bash scripts/run_grpc_deadline_health_conformance_evidence.sh --contract-only --run-id contract-smoke",
    "bash scripts/run_grpc_deadline_health_conformance_evidence.sh --run-id wave2-grpc-deadline-health --timeout-sec 180",
    "bash scripts/run_wave2_capability_evidence_registry.sh --output-root target/wave2-capability-evidence-registry"
