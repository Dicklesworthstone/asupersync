      "metadata_out": "formatted-grpc-timeout",
      "virtual_now": "parser-only",
      "deadline": "unit-round-trip",
      "expected_status": "Ok",
      "actual_status": "observed-by-test",
      "health_state": "not_applicable",
      "cancellation_observed": "false"
