  "decision_contract": {
    "purpose": "Inventory public capability-first examples and deterministic smoke recipes so promoted Wave 2 capabilities are not proven only by private tests.",
    "no_decorative_demo_policy": "Rows must point at an existing user-facing example, documentation recipe, or explicit unsupported reason with a fallback target.",
    "no_private_test_helper_only_policy": "Test-only fixtures are allowed only as fallback targets for unsupported rows, never as the primary example_path for promoted rows.",
    "runtime_dependency_policy": "Examples under examples/ must not introduce tokio, async-std, smol, hyper, reqwest, or axum usage into the core runtime adoption path.",
    "redaction_policy": "Endpoint, token, secret, bearer, password, raw URI, and credential-shaped values must be absent or redacted before recipe logs are passable."
  },
