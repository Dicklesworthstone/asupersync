{
  "contract_version": "mock-code-finder-verification-contract-v1",
  "schema_version": "mock-code-finder-evidence-jsonl-schema-v1",
  "bead_id": "asupersync-qlvtin",
  "artifact_root": "artifacts/mock-code-finder",
  "record_layout": {
    "format": "jsonl",
    "one_record_per_scenario": true,
    "required_fields": [
      "schema_version",
      "bead_id",
      "scenario_id",
      "subsystem",
      "support_class",
      "source_files_inspected",
      "command",
      "rch_command_if_used",
      "cargo_features",
      "test_filter",
      "env_keys_required",
      "deterministic_seed_or_fixture_id",
      "input_artifact",
      "output_artifact",
      "expected_behavior",
      "actual_behavior",
      "verdict",
      "first_failure_line",
      "duration_ms",
      "git_sha_or_tree_state",
      "blocker_bead_id",
      "evidence_quality"
    ],
    "summary_file_suffix": ".summary.json",
    "scenario_file_suffix": ".jsonl"
  },
  "allowed_values": {
    "support_class": [
      "production_live",
      "wire_level",
      "fixture_reference",
      "explicitly_unsupported",
      "blocked_external",
      "audit_only"
    ],
    "verdict": [
      "pass",
      "fail",
      "blocked",
      "unsupported",
      "expected_fail",
      "fixture_only"
    ],
    "evidence_quality": [
      "live",
      "fixture_only",
      "unsupported",
      "expected_fail",
      "blocked"
    ]
  },
  "verdict_evidence_quality": {
    "pass": [
      "live"
    ],
    "fail": [
      "live"
    ],
    "blocked": [
      "blocked"
    ],
    "unsupported": [
      "unsupported"
    ],
    "expected_fail": [
      "expected_fail"
    ],
    "fixture_only": [
      "fixture_only"
    ]
  },
  "artifact_naming": {
    "scenario_jsonl": "artifacts/mock-code-finder/<bead_id>/<scenario_group>.jsonl",
    "summary_json": "artifacts/mock-code-finder/<bead_id>/<scenario_group>.summary.json",
    "input_artifact": "Use a repo-relative path or an empty string when the scenario has no separate input artifact.",
    "output_artifact": "Use a repo-relative path under artifact_root or an empty string when the command itself is the proof."
  },
  "redaction": {
    "env_keys_required_are_names_only": true,
    "forbid_secret_values": true,
    "accepted_secret_placeholder": "<redacted>",
    "forbidden_secret_markers": [
      "password=",
      "passwd=",
      "token=",
      "secret=",
      "api_key=",
      "apikey=",
      "authorization:",
      "database_url=",
      "postgres_url="
    ]
  },
  "acceptance_rules": [
    "Every evidence JSONL file must contain at least one nonblank scenario record.",
    "Each scenario record must include every required field and must set schema_version to mock-code-finder-evidence-jsonl-schema-v1.",
    "A pass or fail verdict must use live evidence_quality and cannot be backed only by audit_only or fixture_reference support.",
    "blocked verdicts must include a blocker_bead_id.",
    "unsupported, expected_fail, and fixture_only records must not be counted as production conformance passes.",
    "env_keys_required must list environment variable names only; values and secrets must be redacted before artifact capture."
  ],
