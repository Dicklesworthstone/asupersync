      "unredacted_secret",
      "unknown_schema_version",
      "unsupported_source_kind"
    ]
  },
  "record_layout": {
    "format": "json",
    "bundle_required_fields": [
      "schema_version",
      "run_id",
      "event_schema_version",
      "generated_at",
      "source_bundle_hash",
      "events",
      "duplicate_policy",
