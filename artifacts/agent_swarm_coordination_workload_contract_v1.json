      "correlation_id",
      "event_kind"
    ],
    "action": "dedupe_then_sort",
    "refusal_reason": "duplicate_event"
  },
  "stale_source_policy": {
    "max_source_age_seconds": 86400,
    "event_time_basis": "event_ts",
    "refusal_reason": "stale_source"
  },
  "allowed_values": {
    "source_kind": [
      "agent_mail",
      "artifact_store",
      "beads",
      "bv",
      "git_dirty_frontier",
      "rch",
      "unknown"
    ],
    "event_kind": [
