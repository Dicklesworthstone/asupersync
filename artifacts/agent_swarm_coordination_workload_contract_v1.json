      "robot_plan_snapshot",
      "rch_job_completed",
      "rch_job_queued",
      "rch_job_started"
    ],
    "command_class": [
      "artifact",
      "coordination",
      "git_state",
      "tracker",
      "validation"
    ],
    "workload_family": [
      "artifact_retrieval_tail",
      "concurrent_rch_proofs",
      "coordination_latency_burst",
      "fail_closed_dirty_frontier",
      "proof_runner_fanout",
      "stale_in_progress_reclaim",
      "tracker_lock_contention"
    ],
    "redaction_verdict": [
      "metadata_only",
      "pseudonymized",
      "redacted",
      "refused"
    ],
    "refusal_reason": [
      "",
      "duplicate_event",
      "missing_required_field",
      "nondeterministic_order",
      "stale_source",
      "unknown_schema_version",
      "unredacted_secret",
      "unsupported_source_kind"
    ]
  },
  "redaction": {
    "forbid_message_body_retention_by_default": true,
    "forbid_raw_env_values": true,
    "forbid_raw_home_paths": true,
    "forbid_raw_hostnames": true,
    "forbid_raw_worker_names": true,
    "accepted_secret_placeholder": "<redacted>",
    "stable_pseudonymization_inputs": [
      "source_kind",
      "source_agent",
      "project_scoped_salt"
    ],
    "report_required_fields": [
      "redacted_field_count",
      "pseudonymized_field_count",
      "metadata_only_field_count",
      "refused_event_count",
      "retained_field_summary"
    ]
  },
  "core_runtime_dependency_policy": {
    "collector_location": "scripts, fixtures, docs, tests, or optional tooling only",
    "forbidden_core_runtime_dependencies": [
      "mcp_agent_mail",
      "agent-mail",
      "beads",
      "br",
      "bv",
      "rch"
    ],
    "allowed_core_runtime_surface": "consume generated JSON fixtures or replay stimuli only"
  },
  "acceptance_rules": [
    "Every event must include all event_required_fields.",
    "Events must be sorted by deterministic_sort_key after duplicate suppression.",
    "Duplicate events are identified by duplicate_policy.dedupe_key and never increase workload pressure counts.",
    "Accepted events must set refusal_reason to the empty string.",
    "Refused events must set redaction_verdict to refused and include a non-empty refusal_reason.",
    "source_kind unknown is valid only for refused events with refusal_reason unsupported_source_kind.",
    "Inputs with unknown schema_version must be refused with unknown_schema_version.",
    "Inputs older than stale_source_policy.max_source_age_seconds must be refused with stale_source.",
    "Runtime workload expansion packs remain optional and must not change the runtime-workload-corpus-v1 core denominator.",
    "The core runtime must not depend on Agent Mail, Beads, bv, or rch libraries."
  ],
