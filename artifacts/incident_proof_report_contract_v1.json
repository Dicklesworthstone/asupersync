    "retained_source_hashes",
    "block_kinds",
    "human_summary"
  ],
  "gate_contract": {
    "mode": "opt-in deterministic fail-closed",
    "direct_main": "does not depend on pull requests or branch-only infrastructure",
    "executable_proofs": "pass and fail reports require at least one proof command routed through rch exec",
    "redaction": "redaction_passed must be true and summaries/commands must not contain secret-like material",
    "fixture_hashes": "expected_fixture_hashes must match retained_source_hashes exactly",
    "malformed_input": "malformed report JSON or JSONL fails closed with malformed_json"
  },
  "scenarios": [
