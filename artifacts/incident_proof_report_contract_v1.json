{
  "schema_version": "incident-proof-report-contract-v1",
  "bead_id": "asupersync-lkygsb.5",
  "module": "src/trace/incident.rs",
  "description": "Operator-facing report and deterministic gate connecting incident import, replay minimization, regression promotion, fallback status, support class, evidence quality, redaction policy, fixture hashes, and exact rch verification commands.",
  "proof_report_schema_version": 1,
  "upstream_contracts": [
    "artifacts/incident_bundle_contract_v1.json",
    "artifacts/incident_replay_minimization_contract_v1.json",
    "artifacts/incident_replay_promotion_contract_v1.json"
  ],
  "report_statuses": [
    "pass",
    "fail",
    "blocked",
    "fixture_only",
    "flaky",
    "unsupported",
    "no_win"
  ],
  "support_classes": [
    "executable_regression",
    "fixture_only",
    "follow_up_required",
    "unsupported",
    "no_win"
  ],
  "evidence_qualities": [
    "trusted",
    "partial",
    "blocked",
    "rejected"
  ],
  "validation_issue_kinds": [
    "malformed_json",
    "unsupported_schema_version",
    "missing_required_field",
    "missing_proof_command",
