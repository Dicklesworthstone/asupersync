    "evidence_quality",
    "gate_success",
    "validation_issue_kinds",
    "block_kinds",
    "proof_command",
    "artifact_path"
  ],
  "proof_commands": [
    "rch exec -- rustfmt --edition 2024 --check src/trace/incident.rs src/trace/mod.rs tests/incident_proof_report.rs",
    "bash scripts/validate_incident_proof_report.sh --output-root target/incident-proof-report --run-id asupersync-lkygsb.5",
    "rch exec -- env CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_incident_proof_report CARGO_INCREMENTAL=0 CARGO_PROFILE_TEST_DEBUG=0 RUSTFLAGS='-D warnings -C debuginfo=0' cargo test -p asupersync --test incident_proof_report --features test-internals -- --nocapture",
    "rch exec -- env CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_incident_proof_report_check CARGO_INCREMENTAL=0 CARGO_PROFILE_DEV_DEBUG=0 RUSTFLAGS='-D warnings -C debuginfo=0' cargo check -p asupersync --test incident_proof_report --features test-internals"
