{
  "contract_version": "runtime-tail-latency-taxonomy-v1",
  "equation": "tail_latency_ns = queueing_ns + service_ns + io_or_network_ns + retries_ns + synchronization_ns + allocator_or_cache_ns + unknown_ns",
  "total_latency_key": "tail.total_latency_ns",
  "unknown_bucket_key": "tail.unknown.unmeasured_ns",
  "required_log_fields": [
    {
      "key": "tail.contract_version",
      "unit": "schema_id",
      "required": true,
      "meaning": "Versioned tail-latency taxonomy contract identifier."
    },
    {
      "key": "tail.total_latency_ns",
      "unit": "ns",
      "required": true,
      "meaning": "Observed end-to-end tail latency for the operation under analysis."
    },
    {
      "key": "tail.queueing.ready_queue_depth",
      "unit": "count",
      "required": true,
      "meaning": "Always-on queueing proxy based on runnable backlog."
    },
    {
      "key": "tail.service.poll_count",
      "unit": "count",
      "required": true,
      "meaning": "Service-side work proxy based on task poll demand."
    },
    {
      "key": "tail.io_or_network.events_received",
      "unit": "count",
      "required": true,
      "meaning": "I/O or network pressure proxy based on reactor event volume."
    },
    {
      "key": "tail.retries.total_delay_ns",
      "unit": "ns",
      "required": true,
      "meaning": "Direct retry/backoff delay accumulated by retry combinators."
    },
    {
      "key": "tail.synchronization.lock_wait_ns",
      "unit": "ns",
      "required": true,
      "meaning": "Direct synchronization delay from contention-instrumented locks."
    },
    {
      "key": "tail.allocator_or_cache.live_allocations",
      "unit": "count",
      "required": true,
      "meaning": "Allocator/cache pressure proxy based on live region-heap allocations."
    },
    {
      "key": "tail.unknown.unmeasured_ns",
      "unit": "ns",
      "required": true,
      "meaning": "Residual latency that remains unattributed after measured terms and proxies are recorded."
    }
  ],
