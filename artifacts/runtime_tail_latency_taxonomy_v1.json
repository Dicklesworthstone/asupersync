  "sampling_policy": [
    "Always emit the required core fields for any tail-latency event, even when extended observability sampling is disabled.",
    "Extended fields may be sampled or emitted only in replay/forensics modes, but they must retain the stable keys defined here.",
    "If a direct-duration field is unavailable for a term, preserve proxy signals and roll the residual duration into tail.unknown.unmeasured_ns."
  ],
  "compatibility_notes": [
    "Structured-log keys are append-only within a contract version; removals or unit changes require a new contract version.",
    "Proxy signals are not interchangeable with direct-duration fields; emitters must preserve both semantics explicitly.",
    "Unknown contribution is mandatory whenever attribution is incomplete so downstream controllers never treat missing data as zero."
  ],
