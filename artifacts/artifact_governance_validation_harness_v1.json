{
  "schema_version": "artifact-governance-validation-harness-v1",
  "harness_id": "artifact_governance_validation_harness_v1",
  "bead_id": "asupersync-artifact-governance-awdiwy.8",
  "created_date": "2026-06-12",
  "purpose": "Provide one deterministic validation surface for artifact-governance schema checks, citation fixtures, supersession fixtures, and e2e-style ledger to scanner to report to signoff flow logs.",
  "source_of_truth": {
    "validation_harness": "artifacts/artifact_governance_validation_harness_v1.json",
    "markdown_report": "docs/proof/artifact_governance_validation_harness.md",
    "contract_test": "tests/artifact_governance_validation_harness_contract.rs",
    "governance_ledger": "artifacts/artifact_governance_ledger_v1.json",
    "scanner": "artifacts/artifact_governance_scanner_v1.json",
    "operator_report": "artifacts/artifact_governance_operator_report_v1.json",
    "producer_checklist": "artifacts/artifact_governance_producer_checklist_v1.json"
  },
  "harness_policy": {
    "corpus_coverage": "deterministic_fixture_harness_not_full_corpus_scan",
    "full_corpus_claim": false,
    "default_scope": "checked_fixtures_and_registered_artifact_governance_rows_only",
    "whole_corpus_scan_policy": "whole corpus scans are opt-in report-only work until their runtime and RCH envelope are separately proven",
    "non_destructive_policy": "The harness reports validation outcomes only. It does not delete, move, rewrite, clean, create branches, create worktrees, or authorize local Cargo fallback for remote-required proof lanes.",
    "remote_required_validation_command": "RCH_REQUIRE_REMOTE=1 RCH_QUEUE_WHEN_BUSY=1 rch exec -- env CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_artifact_governance_validation_harness cargo test -p asupersync --test artifact_governance_validation_harness_contract --test artifact_governance_ledger_contract -- --nocapture",
    "no_local_fallback": true
  },
  "validation_units": [
    {
      "unit_id": "schema_parser_edges",
      "description": "Fixture rows exercise malformed and valid schema/parser surfaces without scanning the whole artifacts tree.",
      "required_fixture_kinds": [
        "valid_citeable_proof_row",
        "missing_owner_row",
        "duplicate_path_row",
        "malformed_no_claim_boundary"
      ],
      "checked_by": "tests/artifact_governance_validation_harness_contract.rs"
    },
    {
      "unit_id": "citation_policy_edges",
      "description": "Fixture rows separate allowed narrow citation from overclaim attempts and advisory-only evidence.",
      "required_fixture_kinds": [
        "allowed_citation",
        "rejected_overclaim",
        "advisory_only"
      ],
      "checked_by": "tests/artifact_governance_validation_harness_contract.rs"
    },
    {
      "unit_id": "supersession_edges",
      "description": "Fixture rows exercise current, superseded, and missing-successor cases with lineage preserved and no cleanup recommendation.",
      "required_fixture_kinds": [
        "current_successor",
        "superseded_with_successor",
        "superseded_missing_successor"
      ],
      "checked_by": "tests/artifact_governance_validation_harness_contract.rs"
    },
    {
      "unit_id": "e2e_flow_log",
      "description": "Deterministic flow log pins the ledger to scanner to report to signoff routing summary and first blocker.",
      "required_fixture_kinds": [
        "ledger_scan_report_signoff"
      ],
      "checked_by": "tests/artifact_governance_validation_harness_contract.rs"
    }
  ],
  "fixture_catalog": {
    "valid_citeable_proof_row": {
      "meaning": "A tracked proof-bearing ledger row with owner, tests, sources, and at least three machine-readable no-claim boundaries.",
      "expected_result": "pass",
      "no_claim_boundary": "does_not_prove_full_workspace_health"
    },
    "missing_owner_row": {
      "meaning": "A row-shaped artifact reference without an owner must fail closed before citation.",
      "expected_result": "fail",
      "expected_error": "missing_owner",
      "no_claim_boundary": "does_not_authorize_deletion"
    },
    "duplicate_path_row": {
      "meaning": "Two rows cannot silently claim the same durable path inside the fixture set.",
      "expected_result": "fail",
      "expected_error": "duplicate_artifact_path",
      "no_claim_boundary": "does_not_select_owner_winner"
    },
    "malformed_no_claim_boundary": {
      "meaning": "No-claim boundaries must stay machine-readable does_not_* tokens.",
      "expected_result": "fail",
      "expected_error": "malformed_no_claim_boundary",
      "no_claim_boundary": "does_not_authorize_overclaims"
    },
    "allowed_citation": {
      "meaning": "A citation may use a proof-bearing row only for the exact claim tokens it declares.",
      "expected_result": "pass",
      "no_claim_boundary": "does_not_expand_claim_scope"
    },
    "rejected_overclaim": {
      "meaning": "A fixture that tries to cite a routing artifact as broad workspace health must fail closed.",
      "expected_result": "fail",
      "expected_error": "citation_overclaim",
      "no_claim_boundary": "does_not_prove_workspace_health"
    },
    "advisory_only": {
      "meaning": "Advisory evidence remains useful context but is rejected as closure-grade proof.",
      "expected_result": "fail",
      "expected_error": "advisory_not_closure_proof",
      "no_claim_boundary": "does_not_close_blockers"
    },
    "current_successor": {
      "meaning": "The current artifact in a supersession chain is citeable only under its own freshness and no-claim policy.",
      "expected_result": "pass",
      "no_claim_boundary": "does_not_prove_no_regression"
    },
    "superseded_with_successor": {
      "meaning": "A superseded artifact passes only as lineage when its successor is explicit.",
      "expected_result": "pass",
      "no_claim_boundary": "does_not_authorize_deletion"
    },
    "superseded_missing_successor": {
      "meaning": "A superseded row without a successor fails closed and still cannot recommend cleanup.",
      "expected_result": "fail",
      "expected_error": "missing_successor",
      "no_claim_boundary": "does_not_delete_superseded_artifact"
    },
    "ledger_scan_report_signoff": {
      "meaning": "The e2e flow fixture logs deterministic counts and first blocker from the committed governance artifacts.",
      "expected_result": "pass",
      "no_claim_boundary": "does_not_prove_release_readiness"
    }
  },
