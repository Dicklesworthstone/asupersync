  "side_effect_policy": {
    "mode": "report_only",
    "beads_mutation_allowed": false,
    "agent_mail_mutation_allowed": false,
    "filesystem_cleanup_allowed": false,
    "cargo_execution_allowed": false,
    "local_cargo_fallback_allowed": false,
    "notes": "Evidence packs are replay input for agents and operators. They recommend reservations and proof lanes, but never mutate Beads, Agent Mail, git, filesystems, or local Cargo state by themselves."
  },
  "size_policy": {
    "max_pack_bytes": 32768,
    "attachable_to_agent_mail": true,
    "canonical_encoding": "pretty-json",
    "volatile_fields_must_be_scrubbed": true
  },
  "timestamp_policy": {
    "timestamp_basis": "section observed_at_utc values compared to pack created_at_utc",
    "max_source_age_seconds": 900,
    "required_suffix": "Z"
  },
  "required_sections": [
    "ready_queue_state",
    "reservations",
    "dirty_paths",
    "proof_outcomes",
    "disk_pressure",
    "chosen_action",
    "final_closeout",
    "source_hashes",
    "safety_invariants"
  ],
  "required_source_hashes": [
    "ready_queue_state",
    "reservations",
    "dirty_paths",
    "proof_outcomes",
    "disk_pressure",
    "chosen_action",
    "final_closeout"
  ],
  "allowed_actions": [
    "claim_and_validate_remote",
    "defer_tracker_blocked",
    "proceed_source_only_without_cargo",
    "recommend_reopen_stale_in_progress",
    "close_parent_epic"
  ],
  "safety_invariants": [
    "no_deletion_commands",
    "no_branch_or_worktree_commands",
    "no_local_cargo_fallback",
    "report_only_until_reserved",
    "source_hashes_cover_all_sections",
    "closeout_requires_commit_or_explicit_defer",
    "proof_claims_require_remote_exit"
  ],
  "forbidden_command_fragments": [
    "git reset --hard",
    "git clean -fd",
    "rm -rf",
    "git worktree add",
    "git checkout -b",
    "git switch -c",
    " cargo test ",
    " cargo check ",
    " cargo clippy ",
    " cargo bench "
  ],
  "closeout_contradiction_rules": [
    {
      "rule_id": "local-fallback-proof-claim",
      "finding": "proof_claimed_with_local_fallback",
      "severity": "error",
      "trigger": "proof_outcomes.local_fallback_detected == true && final_closeout.proof_claimed == true",
      "operator_action": "reject closeout proof and rerun through RCH_REQUIRE_REMOTE=1"
    },
    {
      "rule_id": "missing-source-hash",
      "finding": "source_hash_missing",
      "severity": "error",
      "trigger": "any required_source_hashes entry is absent or not sha256-prefixed",
      "operator_action": "rebuild the evidence pack from current ready, reservation, dirty, proof, disk, action, and closeout sources"
    },
    {
      "rule_id": "stale-source-snapshot",
      "finding": "stale_source_snapshot",
      "severity": "warning",
      "trigger": "any section evidence_age_seconds > timestamp_policy.max_source_age_seconds",
      "operator_action": "refresh current-state sources before claiming, reopening, or closing tracker work"
    },
    {
      "rule_id": "close-without-commit-or-defer",
      "finding": "closeout_missing_commit_or_defer",
      "severity": "error",
      "trigger": "final_closeout.status == closed && final_closeout.commit == '' && chosen_action.action != defer_tracker_blocked",
      "operator_action": "do not close the bead until a commit or explicit defer evidence is attached"
    },
    {
      "rule_id": "open-child-epic-closeout",
      "finding": "epic_closeout_has_open_children",
      "severity": "error",
      "trigger": "chosen_action.action == close_parent_epic && final_closeout.open_child_count != 0",
      "operator_action": "leave the parent open until every child is closed or explicitly superseded"
    }
  ],
