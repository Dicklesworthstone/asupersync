  "smoke_scenarios": [
    {
      "scenario_id": "AA-SCHED-TOPOLOGY-STABLE-RERUN-4W2C",
      "description": "Replay a two-cohort, four-worker steal-heavy fixture twice and require a stable trace hash plus identical steal decisions across reruns.",
      "output_root": "target/scheduler-topology-replay-smoke",
      "command_prefix": "cargo test -p asupersync --test scheduler_topology_replay_artifact -- --nocapture",
      "scenario_class": "deterministic_lab_safe",
      "execution_policy": "execute_only",
      "host_requirements": {
        "min_worker_threads": 4,
        "min_memory_gib": 256,
        "notes": [
          "This scenario is entirely deterministic and safe to run under the lab/runtime test path.",
          "It is the canonical proof that repeated topology replay reruns keep identical steal-path decisions."
        ]
      },
      "capture_plan": [
        "Emit topology_manifest.json from the explicit fixture descriptor rather than ambient host inspection.",
        "Emit topology_trace.json containing the stable hashes, local-vs-remote steal counts, cohort event counts, replay-slot wake-to-run latency by cohort, fairness checks, and detailed steal-path events.",
        "Validate the same fixture produces identical trace hashes across two consecutive reruns without cohort starvation."
      ],
      "fixture": {
        "topology": {
          "worker_threads": 4,
          "cohort_count": 2,
          "memory_budget_gib": 256
        },
        "worker_to_cohort": [
          0,
          0,
          1,
          1
        ],
        "replay_workers": [
          1,
          3
        ],
        "seed": 17,
        "seeded_workers": [
          {
            "worker_id": 0,
            "task_id_start": 10000,
            "task_count": 3
          },
          {
            "worker_id": 2,
            "task_id_start": 20000,
            "task_count": 2
          }
        ]
      },
      "expected_trace": {
        "first_hash": 17382941096260062821,
        "second_hash": 17382941096260062821,
        "event_count": 5,
        "local_steal_count": 3,
        "remote_spill_count": 2,
        "cohort_event_counts": [
          3,
          2
        ],
        "locality_sequence": [
          "local",
          "remote",
          "local",
          "local",
          "remote"
        ],
        "wake_to_run_latency_by_cohort": [
          {
            "cohort_id": 0,
            "slots": [
              1,
              3,
              5
            ]
          },
          {
            "cohort_id": 1,
            "slots": [
              2,
              4
            ]
          }
        ],
        "fairness_checks": {
          "active_replay_cohorts": [
            0,
            1
          ],
          "cohorts_with_events": [
            0,
            1
          ],
          "starvation_free": true,
          "drained_all_seeded_tasks": true
        }
      }
    },
    {
      "scenario_id": "AA-SCHED-TOPOLOGY-REMOTE-SPILL-2W2C",
      "description": "Replay a two-worker, two-cohort fixture that forces one remote spill and records the cross-cohort steal path deterministically.",
      "output_root": "target/scheduler-topology-replay-smoke",
      "command_prefix": "cargo test -p asupersync --test scheduler_topology_replay_artifact -- --nocapture",
      "scenario_class": "deterministic_lab_safe",
      "execution_policy": "execute_only",
      "host_requirements": {
        "min_worker_threads": 2,
        "min_memory_gib": 256,
        "notes": [
          "This scenario isolates the single-remote-spill shape used by the reusable topology helper tests.",
          "It proves that locality labels, wake-to-run slot capture, and fairness checks stay deterministic."
        ]
      },
      "capture_plan": [
        "Emit the explicit two-worker topology manifest used for the remote spill proof.",
        "Emit the remote-steal event with source/thief cohort annotations, local-vs-remote counts, replay-slot wake-to-run latency by cohort, and stable hashes across reruns.",
        "Validate the replay trace reports exactly one remote spill, no locality ambiguity, and no active-cohort starvation."
      ],
      "fixture": {
        "topology": {
          "worker_threads": 2,
          "cohort_count": 2,
          "memory_budget_gib": 256
        },
        "worker_to_cohort": [
          0,
          1
        ],
        "replay_workers": [
          1
        ],
        "seed": 7,
        "seeded_workers": [
          {
            "worker_id": 0,
            "task_id_start": 40000,
            "task_count": 1
          }
        ]
      },
      "expected_trace": {
        "first_hash": 14852217216801945704,
        "second_hash": 14852217216801945704,
        "event_count": 1,
        "local_steal_count": 0,
        "remote_spill_count": 1,
        "cohort_event_counts": [
          0,
          1
        ],
        "locality_sequence": [
          "remote"
        ],
        "wake_to_run_latency_by_cohort": [
          {
            "cohort_id": 1,
            "slots": [
              1
            ]
          }
        ],
        "fairness_checks": {
          "active_replay_cohorts": [
            1
          ],
          "cohorts_with_events": [
            1
          ],
          "starvation_free": true,
          "drained_all_seeded_tasks": true
        }
      }
    }
  ]
