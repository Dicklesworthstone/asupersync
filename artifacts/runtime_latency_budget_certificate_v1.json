    {
      "verdict": "pass",
      "meaning": "Evidence is valid, calibrated, directly attributed enough for certification, and p999 plus uncertainty stays within budget."
    },
    {
      "verdict": "no_win",
      "meaning": "Evidence is valid, but p999 budget, unknown-residual, or asymmetric regression gates prefer the conservative fallback."
    },
    {
      "verdict": "fail_closed",
      "meaning": "Evidence is incomplete, stale, contradictory, hidden, or proxy-only, so no runtime policy should rely on it."
    }
  ],
