    "stale_observation",
    "expired_lease",
    "exclusive_conflict",
    "missing_release",
    "expiring_soon",
    "accept_lease"
  ],
  "freshness_policy": {
    "max_observation_age_seconds": 300,
    "stale_decision": "fail_closed_stale_observation",
    "renew_before_expiry_seconds": 120,
    "notes": "Lease receipts are point-in-time coordination evidence. Stale observations are rejected before interpreting slot availability."
  },
  "decision_rules": [
    {
      "rule_id": "malformed-receipt",
      "priority": 10,
      "trigger": "receipt_status == malformed",
      "decision": "fail_closed_malformed_receipt",
      "required_issue_kind": "malformed_receipt",
      "operator_action": "discard receipt and collect a complete build-slot snapshot"
    },
    {
      "rule_id": "stale-observation",
      "priority": 20,
      "trigger": "observation_age_seconds > freshness_policy.max_observation_age_seconds",
      "decision": "fail_closed_stale_observation",
      "required_issue_kind": "stale_observation",
      "operator_action": "refresh Agent Mail build-slot state before using the receipt"
    },
    {
      "rule_id": "expired-lease",
      "priority": 30,
      "trigger": "lease_state == expired || seconds_until_expiry == 0",
      "decision": "fail_closed_expired",
      "required_issue_kind": "expired_lease",
      "operator_action": "do not count the lease as active; reacquire or wait for the owner to renew"
    },
    {
      "rule_id": "exclusive-conflict",
      "priority": 40,
      "trigger": "exclusive == true && conflicts is nonempty",
      "decision": "fail_closed_exclusive_conflict",
      "required_issue_kind": "exclusive_conflict",
      "operator_action": "coordinate with active holders instead of running a competing build"
    },
    {
      "rule_id": "missing-release",
      "priority": 50,
      "trigger": "release_required == true && release_observed == false",
      "decision": "fail_closed_missing_release",
      "required_issue_kind": "missing_release",
      "operator_action": "treat the slot as uncleared until a release or expiry receipt is observed"
    },
    {
      "rule_id": "expiring-soon",
      "priority": 60,
      "trigger": "seconds_until_expiry <= freshness_policy.renew_before_expiry_seconds",
      "decision": "warn_expiring_soon",
      "required_issue_kind": "lease_expiring_soon",
      "operator_action": "renew before launching a long remote proof lane"
    },
    {
      "rule_id": "accept-lease",
      "priority": 70,
      "trigger": "fresh complete receipt with active lease, no conflicts, no pending release, and enough TTL",
      "decision": "accept_lease",
      "required_issue_kind": "",
      "operator_action": "use the lease as coordination evidence for the scoped remote proof lane"
    }
  ],
  "validation": {
    "json_probe": "jq empty artifacts/build_slot_lease_receipt_contract_v1.json",
