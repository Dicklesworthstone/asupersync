  "trust_levels": [
    {
      "trust_level": "fixture_checked",
      "accepted_for_replay": true,
      "requires_redaction_report": true,
      "notes": "Checked synthetic fixtures and checked sample artifacts."
    },
    {
      "trust_level": "explicit_export",
      "accepted_for_replay": true,
      "requires_redaction_report": true,
      "notes": "Explicit exported JSON/stdout selected by the operator."
    },
    {
      "trust_level": "live_command_output",
      "accepted_for_replay": true,
      "requires_redaction_report": true,
      "notes": "Accepted only after raw env values, hostnames, worker names, and message bodies are removed."
