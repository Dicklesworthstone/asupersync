    {
      "trust_level": "metadata_only",
      "accepted_for_replay": true,
      "requires_redaction_report": true,
      "notes": "Only counts, kinds, hashes, and stable pseudonyms are retained."
    },
    {
      "trust_level": "unknown",
      "accepted_for_replay": false,
      "requires_redaction_report": true,
      "notes": "Unknown inputs can only produce refused events."
    }
  ],
