{
  "contract_version": "roundtrip-oracle-v1",
  "bead_id": "asupersync-wr5m5s",
  "description": "Source-backed oracle catalog for encode/decode, serde, replay, snapshot, TLA projection, and protocol roundtrip surfaces.",
  "source_of_truth": {
    "artifact": "artifacts/roundtrip_oracle_v1.json",
    "contract_test": "tests/roundtrip_oracle_contract.rs",
    "proof_command": "rch exec -- env CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_roundtrip_oracle CARGO_BUILD_JOBS=2 cargo test -p asupersync --test roundtrip_oracle_contract -- --nocapture"
  },
  "oracle_rules": {
    "entry_id_prefix": "roundtrip.",
    "category_prefix": "RoundtripCategory::",
    "source_paths_are_repo_relative": true,
    "source_markers_must_exist": true,
    "proof_command_must_use_rch": true,
    "risk_focus_must_be_nonempty": true,
    "equality_oracle_must_be_nonempty": true
  },
  "roundtrip_categories": [
    {
      "tag": "RoundtripCategory::TypedIdSerde",
      "description": "Core typed identifiers survive JSON serialization and deserialization without losing generation or type identity."
    },
    {
      "tag": "RoundtripCategory::WasmAbiSerde",
      "description": "Browser/WASM ABI envelopes survive JSON serialization with handles and structured failure fields intact."
    },
    {
      "tag": "RoundtripCategory::BrowserCoreAbiSerde",
      "description": "Browser-core JSON payload helpers preserve JS-visible handles and operator-console snapshots across encode/decode boundaries."
    },
    {
      "tag": "RoundtripCategory::RegionSnapshotBinary",
      "description": "Distributed region snapshots encode to deterministic bytes and decode back to equivalent region/task/budget state."
    },
    {
      "tag": "RoundtripCategory::TraceEventSerde",
      "description": "Runtime trace events serialize through JSON and deserialize to the identical typed event."
    },
    {
      "tag": "RoundtripCategory::ReplayTraceBinary",
      "description": "Replay trace binary and MessagePack paths preserve metadata, event variants, and ordering across encode/decode."
    },
    {
      "tag": "RoundtripCategory::OracleReportSerde",
      "description": "Lab oracle reports and evidence ledgers preserve invariant summaries through JSON serialization."
    },
    {
      "tag": "RoundtripCategory::LabDualRunSerde",
      "description": "Dual-run replay and seed-control configuration enums survive JSON serialization without changing execution policy."
    },
    {
      "tag": "RoundtripCategory::CrashpackReplaySerde",
      "description": "Incident replay and minimization crashpack repro artifacts retain replay identity through JSON import/export."
    },
    {
      "tag": "RoundtripCategory::ScenarioSerde",
      "description": "Frankenlab scenario fixtures preserve schema, seed, participants, and fault shape through JSON or YAML."
    },
    {
      "tag": "RoundtripCategory::FrankenSuiteSerde",
      "description": "FrankenSuite typed IDs, decision matrices, and evidence-ledger entries preserve canonical schema through serde roundtrips."
    },
    {
      "tag": "RoundtripCategory::CodecFrame",
      "description": "Framed codec surfaces encode payload bytes and decode the same frame or consume the same wire payload."
    },
    {
      "tag": "RoundtripCategory::ProtocolEnvelope",
      "description": "Protocol-level frames and field sections encode into wire envelopes and decode to equivalent protocol state."
    },
    {
      "tag": "RoundtripCategory::MessagingConfig",
      "description": "Messaging configuration enums and codec selections round-trip through public builder or wire identity surfaces."
    },
    {
      "tag": "RoundtripCategory::RaptorQEncodeDecode",
      "description": "RaptorQ systematic and repair-symbol encode/decode paths recover the original source payload."
    },
    {
      "tag": "RoundtripCategory::TlaProjection",
      "description": "Trace-to-TLA projection stays pinned to deterministic golden behavior for model-checking handoff."
    },
    {
      "tag": "RoundtripCategory::RedisResp3Wire",
      "description": "RESP3 wire fixtures decode to typed Redis values and re-encode byte-for-byte."
    }
  ],
  "roundtrip_entries": [
