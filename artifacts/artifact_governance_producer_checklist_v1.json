{
  "schema_version": "artifact-governance-producer-checklist-v1",
  "checklist_id": "artifact_governance_producer_checklist_v1",
  "bead_id": "asupersync-artifact-governance-awdiwy.5",
  "created_date": "2026-06-12",
  "purpose": "Define the producer workflow and checked guard for adding durable proof, dashboard, signoff, runbook, and contract artifacts without silently bypassing artifact-governance ownership metadata.",
  "source_of_truth": {
    "checklist_artifact": "artifacts/artifact_governance_producer_checklist_v1.json",
    "governance_ledger": "artifacts/artifact_governance_ledger_v1.json",
    "citation_policy": "artifacts/artifact_governance_citation_policy_v1.json",
    "producer_doc": "docs/proof/artifact_governance_producer_checklist.md",
    "contract_test": "tests/artifact_governance_producer_checklist_contract.rs",
    "agent_instructions": "AGENTS.md",
    "readme": "README.md"
  },
  "guard_scope": {
    "corpus_coverage": "guarded_reference_sources_plus_checked_fixtures_not_full_artifacts_tree",
    "full_corpus_claim": false,
    "non_destructive_policy": "The producer guard reports missing ownership metadata only. It does not delete files, clean caches, rewrite artifacts, create branches, create worktrees, or authorize local Cargo fallback for remote-required proof lanes.",
    "guarded_reference_sources": [
      {
        "path": "README.md",
        "parser": "literal_artifacts_json_reference_scan",
        "why_guarded": "README proof sections are high-trust discovery surfaces for agents and operators."
      },
      {
        "path": "AGENTS.md",
        "parser": "literal_artifacts_json_reference_scan",
        "why_guarded": "AGENTS proof instructions are a high-trust policy surface for agents."
      },
      {
        "path": "artifacts/proof_lane_manifest_v1.json",
        "parser": "json_literal_artifacts_reference_scan",
        "why_guarded": "Proof manifest source paths drive proof-citation routing."
      },
      {
        "path": "artifacts/proof_status_snapshot_v1.json",
        "parser": "json_literal_artifacts_reference_scan",
        "why_guarded": "Proof-status rows drive green, blocked, and stale claim routing."
      }
    ],
    "durable_reference_rule": {
      "path_prefix": "artifacts/",
      "path_suffix": ".json",
      "required_metadata": "Every referenced artifacts/*.json path in a guarded source must have a governance-ledger row or an explicit non-citeable exclusion in this checklist.",
      "missing_metadata_error": "missing_governance_metadata"
    }
  },
  "scope": {
    "corpus_coverage": "representative_guard_not_full_corpus",
    "full_corpus_claim": false,
    "non_destructive": true,
    "guard_result_policy": "If a guarded durable artifact reference is missing ownership metadata, the guard should never ask agents to delete files, create branches, create worktrees, or cite local Cargo fallback. The only allowed fail action is to add ownership metadata or an explicit non-citeable exclusion."
  },
  "guard_output_contract": {
    "fail_action": "add_ownership_metadata",
    "operator_message": "Do not delete files. Add an artifact-governance ledger row or explicit non-citeable exclusion with no-claim boundaries.",
    "forbidden_actions": [
      "delete_file",
      "clean_generated_output",
      "create_branch",
      "create_worktree",
      "local_cargo_fallback"
    ]
  },
  "producer_workflow": [
    {
      "step": "classify_path",
      "step_id": "classify-durable-artifact",
      "required_output": "durable_artifact_or_explicit_exclusion",
      "check": "Every guarded artifacts/*.json reference is classified before citation.",
      "requirement": "Before adding a durable artifact, decide whether it is proof-bearing, advisory, blocked-frontier, superseded, generated-fixture, operator-report, or excluded under the ledger taxonomy.",
      "guard_signal": "The contract rejects a guarded artifacts/*.json reference with no ledger row and no explicit exclusion."
    },
    {
      "step": "assign_owner",
      "step_id": "assign-owner",
      "required_output": "owning_bead_and_producing_lane",
      "check": "Durable artifacts carry a ledger row with owning_bead and producing_lane.",
      "requirement": "Add a row to artifacts/artifact_governance_ledger_v1.json for durable artifacts that should be citeable or routeable; use an explicit checklist exclusion only for intentionally non-citeable or pre-backfill references.",
      "guard_signal": "The guard checks the ledger path set and the explicit exclusion path set."
    },
    {
      "step": "declare_citeability",
      "step_id": "declare-citeability",
      "required_output": "citeability_class",
      "check": "The citeability class comes from the ledger taxonomy and controls how agents may cite the artifact.",
      "requirement": "Declare the artifact's citeability class before using it in README, AGENTS, proof-status, or closeout text.",
      "guard_signal": "The guard rejects missing metadata rather than upgrading references to proof."
    },
    {
      "step": "declare_freshness",
      "step_id": "declare-freshness",
      "required_output": "freshness_policy",
      "check": "Rows say when a fresh RCH proof is required and when an artifact is advisory, stale, or blocked.",
      "requirement": "Attach a freshness policy that prevents old reports or blocked frontiers from becoming green proof.",
      "guard_signal": "The guard preserves no-fresh-proof boundaries."
    },
    {
      "step": "attach_no_claim_boundaries",
      "step_id": "attach-no-claim-boundaries",
      "required_output": "does_not_boundaries",
      "check": "Every ledger row or exclusion carries machine-readable does_not_* boundaries.",
      "requirement": "Every ledger row or exclusion must carry machine-readable does_not_* boundaries, including deletion and overclaim boundaries where relevant.",
      "guard_signal": "The contract checks no-claim tokens for the producer checklist, fixtures, and exclusions."
    },
    {
      "step": "wire_checks_and_docs",
      "step_id": "wire-checks-and-docs",
      "required_output": "checked_by_tests_and_source_references",
      "check": "Durable artifacts name the contract tests, docs, and source references that keep the artifact discoverable.",
      "requirement": "Durable artifacts need a focused test, contract, or documented validation lane that verifies their schema and citation limits before they are cited.",
      "guard_signal": "The checklist artifact is checked by tests/artifact_governance_producer_checklist_contract.rs."
    }
  ],
  "required_metadata": [
    "artifact_id",
    "path",
    "path_status",
    "owning_bead",
    "producing_lane",
    "artifact_family",
    "checked_by_tests",
    "citeability_class",
    "freshness_policy",
    "no_claim_boundaries",
    "evidence_scope",
    "source_references"
