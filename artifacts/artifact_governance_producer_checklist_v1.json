  "explicit_exclusions": [
    {
      "id": "remote-build-target-cache-roots",
      "path_pattern": "${TMPDIR:-/tmp}/rch_target_*",
      "reason": "Ephemeral remote target cache pattern; durable governance tracks committed receipts instead.",
      "required_no_claim_boundaries": [
        "does_not_authorize_deletion",
        "does_not_hide_future_durable_receipts",
        "does_not_prove_artifact_absence"
      ]
    },
    {
      "id": "local-target-cache-root",
      "path_pattern": "target/test-artifacts/agent-lane",
      "reason": "Local test artifact directory used for deterministic debugging output; durable governance tracks committed summaries instead.",
      "required_no_claim_boundaries": [
        "does_not_authorize_deletion",
        "does_not_hide_future_durable_receipts",
        "does_not_prove_artifact_absence"
      ]
    }
  ],
  "explicit_reference_exclusions": {
    "reason_code": "preexisting_backfill_pending",
    "reason": "These guarded-source references existed before the A5 producer guard and remain non-citeable through this checklist until A7 or a later backfill adds ledger rows. This explicit exclusion is metadata-only and does not authorize deletion or imply the artifacts are absent.",
    "no_claim_boundaries": [
