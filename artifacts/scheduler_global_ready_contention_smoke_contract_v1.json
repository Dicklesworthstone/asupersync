  "smoke_scenarios": [
    {
      "scenario_id": "AA-SCHED-GLOBAL-READY-FALLBACK-1P",
      "description": "Single-producer shallow burst should stay on the baseline single-pop path with no batch-mode activation.",
      "output_root": "target/scheduler-global-ready-contention-smoke",
      "command_prefix": "cargo test -p asupersync --lib global_ready_contention_contract_scenarios_match_expected_metrics -- --nocapture",
      "scenario_class": "deterministic_lab_safe",
      "execution_policy": "execute_only",
      "fixture": {
        "producer_count": 1,
        "tasks_per_producer": 3,
        "priority": 50
      },
      "expected_metrics": {
        "total_injected": 3,
        "batch_mode_activated": false,
        "fallback_to_baseline": true,
        "min_batch_drains": 0,
        "min_batch_tasks": 0,
        "max_duplicate_dispatches": 0,
        "max_lost_tasks": 0,
        "configured_batch_size": 4,
        "activation_threshold": 8
      }
    },
