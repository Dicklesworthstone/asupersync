    "shrink_hint"
  ],
  "invariant_catalog": [
    {
      "invariant_id": "runtime-quiescent",
      "summary_field": "quiescent",
      "pass_condition": "true",
      "failure_routes_to": "lab/runtime quiescence owner"
    },
    {
      "invariant_id": "all-tracked-tasks-terminal",
      "summary_field": "non_terminal_task_count",
      "pass_condition": "0",
      "failure_routes_to": "scheduler/task lifecycle owner"
    },
    {
      "invariant_id": "cancellation-request-observed",
      "summary_field": "cancellation_requests",
      "pass_condition": "> 0 for cancellation rows",
      "failure_routes_to": "cancel protocol owner"
    },
    {
      "invariant_id": "obligations-resolved",
      "summary_field": "obligation_commits + obligation_aborts",
      "pass_condition": "equals scheduled_task_count * obligations_per_task",
      "failure_routes_to": "obligation lifecycle owner"
    },
    {
      "invariant_id": "losers-drained",
      "summary_field": "quiescent && non_terminal_task_count == 0",
      "pass_condition": "true",
      "failure_routes_to": "combinator/loser-drain owner"
    },
    {
      "invariant_id": "deterministic-replay",
      "summary_field": "trace_digest",
      "pass_condition": "same input scenario produces the same digest and event log",
      "failure_routes_to": "lab replay determinism owner"
    }
  ],
