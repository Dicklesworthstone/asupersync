  "failure_fixtures": [
    {
      "case_id": "missing-cancellation-request",
      "mutates": "fixture_catalog[storm-small-executable].minimum_cancellation_requests",
      "expected_failure": "cancellation storm rows must require at least one cancellation request"
    },
    {
      "case_id": "missing-obligation-resolution",
      "mutates": "required_summary_fields",
      "expected_failure": "obligation commit and abort fields must stay required"
    },
    {
      "case_id": "missing-shrink-metadata",
      "mutates": "fixture_catalog[*].shrink",
