  "proof_lane": {
    "lane_id": "fifth-wave-cancellation-storm-replay-corpus",
    "proof_command_id": "fifth-wave-cancellation-storm-replay-corpus-contract",
    "proof_command": "RCH_REQUIRE_REMOTE=1 rch exec -- env CARGO_TARGET_DIR=${TMPDIR:-/tmp}/rch_target_fifth_wave_cancellation_storm_replay_corpus CARGO_INCREMENTAL=0 CARGO_PROFILE_TEST_DEBUG=0 RUSTFLAGS='-D warnings -C debuginfo=0' cargo test -p asupersync --test fifth_wave_cancellation_storm_replay_corpus_contract -- --nocapture",
    "local_fallback_allowed": false,
    "does_not_cover": [
      "does not prove broad cancellation correctness",
      "does not prove broad workspace health",
      "does not replace DPOR or formal proofs",
      "does not implement production admission policy"
    ]
  },
  "required_summary_fields": [
    "schema_version",
    "scenario_id",
    "seed",
    "worker_count",
    "cohort_count",
    "region_count",
    "task_count",
