  "purpose": "Deterministic replay-corpus contract for cancellation storms, obligation pressure, loser drain, and region-close quiescence under swarm-scale fanout.",
  "source_of_truth": {
    "atlas_artifact": "artifacts/fifth_wave_swarm_control_plane_atlas_v1.json",
